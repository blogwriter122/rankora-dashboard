# ── Dashboard env (set these in Vercel → Settings → Environment Variables) ──

# Supabase (anon key — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Your local/VPS engine API (the engine/server.js endpoint).
# Local testing: http://localhost:3100
# Production: your VPS public URL or a tunnel (e.g. Cloudflare Tunnel / ngrok)
NEXT_PUBLIC_ENGINE_URL=http://localhost:3100
